{
  "entities": {
    "UserProfile": {
      "title": "User Profile",
      "description": "Public and private profile data for a TACTIK user.",
      "type": "object",
      "properties": {
        "uid": { "type": "string", "description": "Firebase Auth UID" },
        "username": { "type": "string", "description": "Unique handle" },
        "displayName": { "type": "string", "description": "Display name" },
        "title": { "type": "string", "description": "Professional title" },
        "bio": { "type": "string", "description": "Short biography" },
        "whatsapp": { "type": "string", "description": "WhatsApp contact number" },
        "email": { "type": "string", "description": "Contact email" },
        "website": { "type": "string", "description": "Personal or business website" },
        "socialLinks": {
          "type": "object",
          "properties": {
            "linkedin": { "type": "string" },
            "twitter": { "type": "string" },
            "instagram": { "type": "string" }
          }
        },
        "viewCount": { "type": "number", "description": "Total profile views/taps" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "username", "displayName"]
    },
    "Username": {
      "title": "Username Mapping",
      "description": "Maps a unique username to a UID.",
      "type": "object",
      "properties": {
        "uid": { "type": "string" }
      },
      "required": ["uid"]
    },
    "Order": {
      "title": "Card Order",
      "description": "NFC card order details.",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "username": { "type": "string" },
        "status": { "type": "string", "enum": ["pending", "paid", "shipped", "cancelled"] },
        "amount": { "type": "number" },
        "shippingAddress": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "username", "status", "amount", "shippingAddress", "createdAt", "updatedAt"]
    }
  },
  "firestore": {
    "profiles/{uid}": {
      "schema": "UserProfile",
      "description": "User profile documents."
    },
    "usernames/{username}": {
      "schema": "Username",
      "description": "Username to UID mapping."
    },
    "orders/{orderId}": {
      "schema": "Order",
      "description": "NFC card orders."
    }
  }
}
