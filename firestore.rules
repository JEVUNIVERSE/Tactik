rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: profiles
    // Document ID: {uid}
    // Fields:
    //   - uid: string (required)
    //   - username: string (required)
    //   - displayName: string (required)
    //   - title: string (optional)
    //   - bio: string (optional)
    //   - whatsapp: string (optional)
    //   - email: string (optional)
    //   - website: string (optional)
    //   - socialLinks: map (optional)
    //   - viewCount: number (required)
    //   - updatedAt: string (required)
    //
    // Collection: usernames
    // Document ID: {username}
    // Fields:
    //   - uid: string (required)
    //
    // Collection: orders
    // Document ID: {orderId}
    // Fields:
    //   - uid: string (required)
    //   - username: string (required)
    //   - status: string (required, enum)
    //   - amount: number (required)
    //   - shippingAddress: string (required)
    //   - createdAt: string (required)
    //   - updatedAt: string (required)
    //
    // ===============================================================

    // ===============================================================
    // Helper Functions
    // ===============================================================
    
    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isAdmin() {
      return isAuthenticated() && 
        (get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin' || 
         (request.auth.token.email == "jevuniverse@gmail.com" && request.auth.token.email_verified == true));
    }

    function isValidProfile(data) {
      return data.keys().hasAll(['uid', 'username', 'displayName', 'viewCount', 'updatedAt']) &&
             data.uid is string &&
             data.username is string && data.username.matches('^[a-zA-Z0-9_]{3,20}$') &&
             data.displayName is string && data.displayName.size() > 0 && data.displayName.size() < 100 &&
             data.viewCount is number &&
             data.updatedAt is string;
    }

    function isValidOrder(data) {
      return data.keys().hasAll(['uid', 'username', 'status', 'amount', 'shippingAddress', 'createdAt', 'updatedAt']) &&
             data.uid is string &&
             data.username is string &&
             data.status in ['pending', 'paid', 'shipped', 'cancelled'] &&
             data.amount is number &&
             data.shippingAddress is string && data.shippingAddress.size() > 0 && data.shippingAddress.size() < 1000 &&
             data.createdAt is string &&
             data.updatedAt is string;
    }

    // ===============================================================
    // Rules
    // ===============================================================

    match /profiles/{uid} {
      allow read: if true; // Public profiles
      allow create: if isOwner(uid) && isValidProfile(request.resource.data);
      allow update: if (isOwner(uid) && isValidProfile(request.resource.data)) || 
                      (request.resource.data.diff(resource.data).affectedKeys().hasOnly(['viewCount']) && 
                       request.resource.data.viewCount == resource.data.viewCount + 1);
    }

    match /usernames/{username} {
      allow read: if true;
      allow create: if isAuthenticated() && request.resource.data.uid == request.auth.uid;
    }

    match /orders/{orderId} {
      allow read: if isOwner(resource.data.uid) || isAdmin();
      allow create: if isAuthenticated() && request.resource.data.uid == request.auth.uid && isValidOrder(request.resource.data);
      allow update, delete: if isAdmin();
    }
    
    match /users/{userId} {
      allow read, write: if isOwner(userId) || isAdmin();
    }
  }
}
